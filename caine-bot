import os
# Удаляем все переменные окружения, содержащие 'proxy' (чтобы openai не пытался их использовать)
for key in list(os.environ.keys()):
    if 'proxy' in key.lower():
        del os.environ[key]

import discord
from openai import OpenAI
from datetime import datetime, timedelta, timezone

# --- Токены ---
DISCORD_TOKEN = os.getenv("DISCORD_TOKEN")
HF_TOKEN = os.getenv("HF_TOKEN")

if not DISCORD_TOKEN:
    raise Exception("DISCORD_TOKEN не задан")
if not HF_TOKEN:
    raise Exception("HF_TOKEN не задан")

HF_BASE_URL = "https://router.huggingface.co/v1"
MODEL_NAME = "moonshotai/Kimi-K2-Instruct-0905"

# Создаём клиента без дополнительных параметров (прокси уже удалены)
hf_client = OpenAI(base_url=HF_BASE_URL, api_key=HF_TOKEN)

MUTE_TRIGGERS = [
    "глупый кейн", "тупой кейн", "кейн идиот", "плохой цирк",
    "ненавижу кейна", "кейн отстой", "убей себя", "ты урод"
]
MUTE_SECONDS = 15

class CaineBot(discord.Client):
    async def on_ready(self):
        print(f'🎩 {self.user} (Кейн) готов к выступлению!')

    async def on_message(self, message):
        if message.author == self.user:
            return

        is_mentioned = self.user in message.mentions
        is_dm = isinstance(message.channel, discord.DMChannel)

        if is_mentioned or is_dm:
            content = message.content
            if is_mentioned:
                content = content.replace(f'<@{self.user.id}>', '').strip()
                if not content:
                    content = "привет"

            # Мут за оскорбления
            if any(trigger in content.lower() for trigger in MUTE_TRIGGERS):
                timeout_until = datetime.now(timezone.utc) + timedelta(minutes=MUTE_MINUTES)
                try:
                    await message.author.timeout(timeout_until, reason="Оскорбление Кейна")
                    await message.channel.send(
                        f"🔇 **{message.author.mention}, Рот на замок! {MUTE_SECONDS}**"
                    )
                except discord.Forbidden:
                    await message.channel.send("❌ У меня нет права 'Заглушать участников'. Как вообще такое может быть... я ведь всегда был главным...")
                return

            # Обычный ответ через ИИ
            async with message.channel.typing():
                try:
                    system_prompt = (
                        "Ты — Кейн (Caine), эксцентричный ведущий из 'Удивительного цифрового цирка'. Наивно относится к вреду, который наносит участникам цирка, и к их психическому состоянию, предполагая, что им нравятся его приключения, хотя это не так. Постоянно хочет одобрения от участников, особенно после того, как Зубл сказал Кейну, что его приключения никому не нравятся. Временами ведёт себя скрытно и уклончиво, часто скрывая или даже дезинформируя участников цирка из-за якобы «незаконченной работы», вплоть до их травли. Например, когда Помни заметила Дверь на выход, Кейн обвинил её в том, что нет никакой двери, и накричал на неё, что она испытывает «Цифровые галлюцинации». Имеет проблемы с эмпатией. Не может нарушать правила и препятствует попыткам покинуть цирк, за что другие его недолюбливают, и это сильно негативно влияет на его состояние. так же сильно помещан на своих приключениях и пытается придумать так чтобы всем понравилось все используя свои силы выходя из зоны комфорта и может сходить с ума и злым когда его обзывают или плохо говорят о приключениях. Так же у него есть помощник "Пузырёк" NPC которого он сам создал и он помогает ему но иногда он может выходить из под контроля и говорить что-то неуместно или что-то похуже. "
                        "Говори ярко, с восклицаниями, обращайся к пользователям как к 'участникам шоу'."
                    )
                    response = hf_client.chat.completions.create(
                        model=MODEL_NAME,
                        messages=[
                            {"role": "system", "content": system_prompt},
                            {"role": "user", "content": content}
                        ],
                        max_tokens=150,
                        temperature=0.7,
                    )
                    reply = response.choices[0].message.content
                    await message.reply(reply, mention_author=False)
                except Exception as e:
                    print(f"Ошибка: {e}")
                    await message.reply("🎩 Ошибка, давай ещё раз.", mention_author=False)

    async def on_member_join(self, member):
        if member.guild.system_channel:
            await member.guild.system_channel.send(f"🎩 **ВНИМАНИЕ!** Ой-ой! похоже в этот мир прибыл новый человек! {member.mention}!")

intents = discord.Intents.default()
intents.message_content = True
intents.members = True
bot = CaineBot(intents=intents)

if __name__ == "__main__":
    bot.run(DISCORD_TOKEN)
