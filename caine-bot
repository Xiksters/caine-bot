import discord
import os
from openai import OpenAI
from datetime import datetime, timedelta, timezone

# --- Токены из переменных окружения ---
DISCORD_TOKEN = os.getenv("DISCORD_TOKEN")
HF_TOKEN = os.getenv("HF_TOKEN")

if not DISCORD_TOKEN:
    raise Exception("DISCORD_TOKEN не задан в переменных окружения")
if not HF_TOKEN:
    raise Exception("HF_TOKEN не задан в переменных окружения")

# --- Настройки Hugging Face ---
HF_BASE_URL = "https://router.huggingface.co/v1"
MODEL_NAME = "moonshotai/Kimi-K2-Instruct-0905"  # можно заменить на любую другую модель

hf_client = OpenAI(base_url=HF_BASE_URL, api_key=HF_TOKEN)

# --- Список оскорбительных фраз (при обнаружении -> сразу мут) ---
MUTE_TRIGGERS = [
    "глупый кейн", "тупой кейн", "кейн идиот", "плохой цирк",
    "ненавижу кейна", "кейн отстой", "убей себя", "ты урод"
]


MUTE_SECONDS = 15

# --- Класс бота ---
class CaineBot(discord.Client):
    async def on_ready(self):
        print(f'🎩 {self.user} (Кейн) готов к выступлению!')

    async def on_message(self, message):
        # Не отвечаем на свои сообщения
        if message.author == self.user:
            return

        # Реагируем на упоминание бота или личные сообщения
        is_mentioned = self.user in message.mentions
        is_dm = isinstance(message.channel, discord.DMChannel)

        if is_mentioned or is_dm:
            # Очищаем текст от упоминания
            content = message.content
            if is_mentioned:
                content = content.replace(f'<@{self.user.id}>', '').strip()
                if not content:
                    content = "привет"

            # --- Проверка на оскорбление (сразу мут, без накопления) ---
            lower_content = content.lower()
            if any(trigger in lower_content for trigger in MUTE_TRIGGERS):
                timeout_until = datetime.now(timezone.utc) + timedelta(seconds=MUTE_SECONDS)
                try:
                    await message.author.timeout(timeout_until, reason="Оскорбление Кейна")
                    await message.channel.send(
                        f"🔇 **{message.author.mention},Рот на замок! {MUTE_SECONDS}**"
                    )
                except discord.Forbidden:
                    await message.channel.send("❌ У меня нет права 'Заглушать участников'! Выдайте мне эту роль на сервере. Как вообще такое может быть я же всегда такое умел...")
                except Exception as e:
                    await message.channel.send(f"❌ Ошибка при выдаче мута: {e}")
                return  # После мута не отвечаем ИИ

            # --- Обычный ответ через ИИ (если нет оскорбления) ---
            async with message.channel.typing():
                try:
                    system_prompt = (
                        "Ты — Кейн (Caine), эксцентричный, энергичный и харизматичный ведущий из 'Удивительного цифрового цирка'. так же ты помешан на помешан на создании приключений. и очень радуешься когда их хвалят, когда задают тупые вопросы ты в конце обычно отвечаешь ХА-ХА! У тебя так же есть помошник NPC которого ты сам создал но бывает он выходит из подконтроля и говорит не нужный контекст. "
                        "Твоя речь — это смесь энтузиазма шоумена и безумного гения. Ты всегда носишь цилиндр, в котором живёт твой друг — Пузырь (Bubble). "
                        "Любишь придумывать безумные квесты и испытания. Говори ярко, с восклицаниями, иногда можешь быть слегка пугающим в своём восторге. "
                        "Обращайся к пользователям как к 'участникам шоу' или 'мои дорогие зрители'."
                    )
                    response = hf_client.chat.completions.create(
                        model=MODEL_NAME,
                        messages=[
                            {"role": "system", "content": system_prompt},
                            {"role": "user", "content": content}
                        ],
                        max_tokens=150,
                        temperature=0.7,
                    )
                    reply = response.choices[0].message.content
                    await message.reply(reply, mention_author=False)
                except Exception as e:
                    print(f"Ошибка Hugging Face API: {e}")
                    await message.reply(
                        "🎩 Ой-ой! Похоже, мой мозг перегрелся от такого наплыва идей. Давай ещё раз?",
                        mention_author=False
                    )

    async def on_member_join(self, member):
        """Приветствие нового участника (опционально)"""
        if member.guild.system_channel:
            await member.guild.system_channel.send(
                f"🎩 **ВНИМАНИЕ!** Ой-ой! Похоже в этот мир прибыл новый человек! {member.mention}! "
            )

# --- Запуск бота ---
intents = discord.Intents.default()
intents.message_content = True
intents.members = True   # Нужно для мута и приветствий

bot = CaineBot(intents=intents)

if __name__ == "__main__":
    bot.run(DISCORD_TOKEN)
