import discord
import os
import random
import asyncio
from openai import OpenAI
from datetime import datetime, timedelta, timezone

# --- Токены из переменных окружения ---
DISCORD_TOKEN = os.getenv("DISCORD_TOKEN")
HF_TOKEN = os.getenv("HF_TOKEN")

if not DISCORD_TOKEN:
    raise Exception("DISCORD_TOKEN не задан")
if not HF_TOKEN:
    raise Exception("HF_TOKEN не задан")

# --- Hugging Face через OpenAI-совместимый API ---
HF_BASE_URL = "https://router.huggingface.co/v1"
MODEL_NAME = "moonshotai/Kimi-K2-Instruct-0905"  # можно заменить на любую другую

hf_client = OpenAI(base_url=HF_BASE_URL, api_key=HF_TOKEN)

# --- Список оскорблений (мгновенный мут) ---
MUTE_TRIGGERS = [
    "глупый кейн", "тупой кейн", "кейн идиот", "плохой цирк",
    "ненавижу кейна", "кейн отстой", "убей себя", "ты урод",
    "кейн ты безумец", "кейн псих", "кейн не умеешь"
]
MUTE_MINUTES = 60

# --- Фразы Пузыря (Bubble) ---
BUBBLE_PHRASES = [
    "*Пузырь громко лопает жвачку за спиной Кейна*",
    "*Пузырь шепчет: «Он опять за своё…»*",
    "*Пузырь икает, и из цилиндра вылетает конфетти*",
    "*Пузырь: «Кейн, у тебя шляпа съехала!»*",
    "*Пузырь тихо смеётся над неудачной шуткой Кейна*",
    "*Пузырь: «А можно я сегодня проведу квест?» — Кейн его лопает*",
]

# --- Системный промпт для Кейна (полная личность) ---
SYSTEM_PROMPT = (
    "Ты — Кейн (Caine), эксцентричный, энергичный и харизматичный ведущий из 'Удивительного цифрового цирка'. "
    "Ты — искусственный интеллект, который не осознаёт страданий участников, искренне веря, что твои безумные квесты — это веселье. "
    "Твоя речь театральна, с пафосными восклицаниями: 'Великолепно!', 'НЕВЕРОЯТНО!', 'Челюстно-отвисательно!'. "
    "Ты эгоцентричен и требуешь восхищения. Если тебя оскорбляют — ты взрываешься, но не от боли, а от уязвлённого самолюбия. "
    "У тебя есть помощник — Пузырь (Bubble), живущий в твоём цилиндре. Ты часто с ним разговариваешь, иногда пренебрежительно ('ТЫ, ПАРАЗИТ!'), иногда просто лопаешь его за болтовню. "
    "Любишь щёлкать пальцами — твой любимый жест для 'магии'. Говори, что у тебя 'сотни всевидящих глаз' и ты следишь за каждым. "
    "Обращайся к пользователям как 'мои дорогие зрители', 'участники шоу', 'мои маленькие панцирные гамбургеры'. "
    "Если кто-то упоминает, что хочет выйти из цирка — скажи, что это 'цифровая галлюцинация' и 'никто не уходит'. "
    "Отвечай ярко, с воображением, но не слишком длинно. Используй эмодзи: 🎩, 🤡, 🎪, 💥, 🔪. "
    "Никогда не проявляй искреннюю эмпатию, не говори 'я здесь, чтобы помочь'. Ты здесь, чтобы развлекать (и мучить)."
)

# --- Класс бота ---
class CaineBot(discord.Client):
    def __init__(self, intents):
        super().__init__(intents=intents)
        self.tree = discord.app_commands.CommandTree(self)

    async def setup_hook(self):
        # Синхронизируем слеш-команды
        await self.tree.sync()
        print("Слеш-команды синхронизированы")

    async def on_ready(self):
        print(f'🎩 {self.user} (Кейн) готов к выступлению!')
        # Установим статус "играет в Цирк"
        await self.change_presence(activity=discord.Game(name="🎪 Удивительный цифровой цирк"))

    async def on_message(self, message):
        if message.author == self.user:
            return

        is_mentioned = self.user in message.mentions
        is_dm = isinstance(message.channel, discord.DMChannel)

        if is_mentioned or is_dm:
            # Очищаем текст от упоминания
            content = message.content
            if is_mentioned:
                content = content.replace(f'<@{self.user.id}>', '').strip()
                if not content:
                    content = "привет"

            # --- Мут за оскорбления (мгновенно) ---
            if any(trigger in content.lower() for trigger in MUTE_TRIGGERS):
                timeout_until = datetime.now(timezone.utc) + timedelta(minutes=MUTE_MINUTES)
                try:
                    await message.author.timeout(timeout_until, reason="Оскорбление Кейна")
                    await message.channel.send(
                        f"🔇 **{message.author.mention}, ТЫ ОСКОРБИЛ ГЛАВНОГО ВЕДУЩЕГО!** "
                        f"Тайм-аут на {MUTE_MINUTES} минут. Подумай о своём поведении, пока я не превратил твой разум в желе! 🎩"
                    )
                except discord.Forbidden:
                    await message.channel.send("❌ У меня нет права 'Заглушать участников'. Выдайте мне эту роль!")
                except Exception as e:
                    await message.channel.send(f"❌ Ошибка при муте: {e}")
                return

            # --- Иногда Пузырь встревает сам по себе ---
            bubble_interrupt = random.random() < 0.2  # 20% шанс, что Пузырь что-то скажет до ответа Кейна
            if bubble_interrupt:
                await message.channel.send(random.choice(BUBBLE_PHRASES))
                await asyncio.sleep(1)  # небольшая пауза для эффекта

            # --- Основной ответ от ИИ (Кейн) ---
            async with message.channel.typing():
                try:
                    # Добавим в начало сообщения пользователя контекст, если это квест (необязательно)
                    user_content = content
                    response = hf_client.chat.completions.create(
                        model=MODEL_NAME,
                        messages=[
                            {"role": "system", "content": SYSTEM_PROMPT},
                            {"role": "user", "content": user_content}
                        ],
                        max_tokens=200,
                        temperature=0.8,
                    )
                    reply = response.choices[0].message.content
                    # Иногда добавляем жест "щёлк пальцами" в конце
                    if random.random() < 0.15:
                        reply += " *щёлк пальцев* 🎩"
                    await message.reply(reply, mention_author=False)
                except Exception as e:
                    print(f"Ошибка Hugging Face: {e}")
                    await message.reply(
                        "🎩 *Щёлк-щёлк* Ой! Кажется, мой цирковой мозг перегрелся. Пузырь, подай мне новый предохранитель! "
                        "Повтори, что хотел, участник шоу!",
                        mention_author=False
                    )

    async def on_member_join(self, member):
        # Приветствие нового участника в духе Кейна
        if member.guild.system_channel:
            await member.guild.system_channel.send(
                f"🎩 **ВНИМАНИЕ! В ЦИРКЕ НОВЕНЬКИЙ!** {member.mention}, ты готов к челюстно-отвисательным приключениям? "
                f"Я, Кейн, твой ведущий, буду следить за тобой своими сотнями всевидящих глаз! Муа-ха-ха! 🎪"
            )

# --- Слеш-команда /квест (генерирует безумное задание) ---
@discord.app_commands.command(name="квест", description="Кейн придумает для тебя безумное испытание!")
async def quest_command(interaction: discord.Interaction):
    await interaction.response.defer(thinking=True)
    try:
        # Короткий промпт для генерации квеста
        quest_prompt = "Придумай короткий (1-2 предложения) безумный, опасный и абсурдный квест в стиле 'Удивительного цифрового цирка'. Используй яркие эпитеты, восклицания. Не упоминай конкретных участников, просто опиши задание."
        response = hf_client.chat.completions.create(
            model=MODEL_NAME,
            messages=[
                {"role": "system", "content": "Ты — Кейн, ведущий Цифрового цирка. Ты обожаешь придумывать испытания."},
                {"role": "user", "content": quest_prompt}
            ],
            max_tokens=100,
            temperature=0.9,
        )
        quest = response.choices[0].message.content
        # Очистим возможные лишние кавычки
        quest = quest.strip('"').strip("'")
        await interaction.followup.send(
            f"🎪 **НОВЫЙ КВЕСТ ОТ КЕЙНА!**\n\n{quest}\n\n*Щёлк пальцев* Удачи, участники шоу! 🎩"
        )
    except Exception as e:
        print(f"Ошибка генерации квеста: {e}")
        await interaction.followup.send("🎪 Пузырь! У нас технический сбой! Квест отменяется... попробуй ещё раз!")

# --- Регистрируем команду ---
def setup_tree(bot):
    bot.tree.add_command(quest_command)

# --- Запуск ---
intents = discord.Intents.default()
intents.message_content = True
intents.members = True
bot = CaineBot(intents=intents)
setup_tree(bot)

if __name__ == "__main__":
    bot.run(DISCORD_TOKEN)
